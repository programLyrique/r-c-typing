larger_than_3: ∀'a,'b. (t(^int[^(1 & int('b))] & 'a) -> ^int[^(1 & int('b))] & 'a) & (t(int[^(1 & int('b))] & 'a) -> int[^(1 & int('b))] & 'a)

size_bound: ∀'a,'b. t(vec[^((..10) & int('b))] & 'a) -> vec[^((..10) & int('b))] & 'a

bail_if: t(c_false, c_string) | t(c_int_na \ c_false, c_string) -> ()

cond_on_int: ∀'a. t(c_false & 'a) -> c_false & 'a

isNull: t(*c_int_na \ c_null) -> c_false

C_escape_chars: t(chr) -> ()

C_escape_chars_one: ∀'a. t(any_sexp & 'a) -> any_sexp & 'a

C_escape_chars2: ∀'a,'b,'c,'d. (t(chr[^(0 & int('b))] & 'a) -> chr[^(0 & int('b))] & 'a) & (t(v("" | chr & 'd) & 'a) -> v("" | chr & 'd)) & (t(v[^int('c)]("" | chr & 'd) & 'a) -> v[^int('c)]("" | chr & 'd))

strstr: t(c_string, c_string) --> c_string

R_split_string: t(chr, chr) -> chr2

