change_int: ∀'a. (t(^int & 'a) -> ^int & 'a) & (t(int & 'a) -> int & 'a)

errorIntScalar: t(int1) -> ()

make_scalar: () -> int1

isIntScalar: (t(int1) -> c_true) & (t(int[^(int \ 1)]) | t(p(chr) | vec & ~int) -> c_false)

check: () -> c_false

incr: t(int1) -> int1

isFunction: t(arrow) --> c_true & t(~arrow) --> c_false

isPrimitive: (t(any -> any) -> c_true) & (t((env | externalptr | lang | list | vec | arrow \ (any -> any)) | null | p(chr) | sym) -> c_false)

isList: (t((env | externalptr | list | vec | arrow) | p(chr) | sym) -> c_false) & (t(lang) | t(null) -> c_true)

isNewList: (t((env | externalptr | lang | vec | arrow) | p(chr) | sym) -> c_false) & (t(list) | t(null) -> c_true)

