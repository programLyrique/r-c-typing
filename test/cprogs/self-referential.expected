head: ∀'a. *{ value : c_int_na & 'a ; next : x1 } \ c_null -> 'a where x1 = *{ value : c_int_na ; next : x1 }

tail: ∀'a. *{ value : c_int_na ; next : *x1 & 'a } \ c_null -> 'a where x1 = { value : c_int_na ; next : *x1 }

root: ∀'a. *{ value : c_int_na & 'a ; left : x1 ; right : x1 } \ c_null -> 'a where x1 = *{ value : c_int_na ; left : x1 ; right : x1 }

