head: ∀'a. t(*{ value : c_int_na & 'a ; next : x1 }) -> 'a where x1 = *{ value : c_int_na ; next : x1 }

tail: ∀'a. t(*{ value : c_int_na ; next : *x1 & 'a }) -> 'a where x1 = { value : c_int_na ; next : *x1 }

root: ∀'a. t(*{ value : c_int_na & 'a ; left : x1 ; right : x1 }) -> 'a where x1 = *{ value : c_int_na ; left : x1 ; right : x1 }

